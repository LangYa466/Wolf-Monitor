# ─────────────────────────────────────────────────────────────────────────────
# Wolf-Monitor master — the ONLY required configuration is the database URL.
# Everything else (admin account, node token, ipinfo token, notification
# channels) is configured from the dashboard and stored in PostgreSQL.
# ─────────────────────────────────────────────────────────────────────────────

# Remote PostgreSQL connection string (Neon / Supabase / RDS / self-hosted).
# Managed providers require SSL (on by default). Append ?sslmode=disable for a
# local/plaintext database. Use the POOLED connection string on serverless.
DATABASE_URL=postgresql://user:password@host:5432/wolf

# ── Optional (almost never needed) ──────────────────────────────────────────
# PGSSL=disable          # force-disable SSL even on a remote URL (plaintext)
# PGSSL=no-verify        # keep TLS but skip cert verification (last resort)
# PG_CA_CERT=...         # CA cert (PEM or base64-PEM) for a private/managed CA
# PG_POOL_MAX=4          # max Postgres pool connections (keep small on serverless)
# CRON_SECRET=...        # if set, /api/cron/check requires Authorization: Bearer <secret>
#                        # (Vercel Cron sends it automatically when this env is set)
# EVAL_INTERVAL_MS=30000 # self-host (server.js) evaluation loop interval
# PORT=8080  HOST=0.0.0.0  # self-host (server.js) bind address
